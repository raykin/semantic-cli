#!/usr/bin/env ruby
require 'semantic_cli'

WIFI_IF = if macos?
            candidates = `networksetup -listallhardwareports | awk '/Wi-Fi|802\\.11/{getline; print $2}'`.strip.split("\n")
            candidates.find { |iface| `ifconfig #{iface} 2>/dev/null`.include?('status: active') } || candidates.first
          else
            `nmcli -t -f DEVICE,TYPE dev | grep wifi | head -1 | cut -d: -f1`.strip
          end

# networksetup proxy/DNS commands take the network *service* name (e.g. "Wi-Fi"),
# not the interface (e.g. "en0"). Resolve the service name for WIFI_IF.
WIFI_SERVICE = if macos?
                 order = `networksetup -listnetworkserviceorder`
                 order[/\(\d+\)\s+(.+)\n\(Hardware Port:[^)]*Device:\s*#{WIFI_IF}\)/, 1]&.strip || 'Wi-Fi'
               end

fn 'proxy' do |c1='display'|
  if macos?
    case c1
    when 'on'
      "networksetup -setsocksfirewallproxystate '#{WIFI_SERVICE}' on"
    when 'off'
      "networksetup -setsocksfirewallproxystate '#{WIFI_SERVICE}' off"
    else
      "networksetup -getsocksfirewallproxy '#{WIFI_SERVICE}'"
    end
  else
    case c1
    when 'on'
      "gsettings set org.gnome.system.proxy mode manual"
    when 'off'
      "gsettings set org.gnome.system.proxy mode none"
    when 'auto'
      "gsettings set org.gnome.system.proxy mode auto"
    else
      "gsettings get org.gnome.system.proxy mode && gsettings get org.gnome.system.proxy.socks host && gsettings get org.gnome.system.proxy.socks port"
    end
  end
end

fn 'dns' do |c1=nil, *rest|
  if macos?
    case c1
    when 'set'
      "networksetup -setdnsservers '#{WIFI_SERVICE}' #{rest.join(" ")}"
    else
      "networksetup -getdnsservers '#{WIFI_SERVICE}'"
    end
  else
    case c1
    when 'set'
      "resolvectl dns #{WIFI_IF} #{rest.join(" ")}"
    else
      "resolvectl dns #{WIFI_IF}"
    end
  end
end

fn '' do
  if macos?
    system "networksetup -getairportnetwork #{WIFI_IF} && ipconfig getifaddr #{WIFI_IF} && networksetup -getsocksfirewallproxy '#{WIFI_SERVICE}'"
  else
    system "echo 'SSID:' $(iwgetid -r) && echo 'IP:' $(ip -4 addr show #{WIFI_IF} | grep -oP 'inet \\K[\\d.]+') && echo 'Proxy:' $(gsettings get org.gnome.system.proxy mode)"
  end
  if macos?
    <<~HELP

      Commands:
        wifi proxy on/off → enable/disable socks proxy
        wifi proxy        → show proxy details
        wifi dns          → show DNS servers
        wifi dns set 8.8.8.8 8.8.4.4 → set DNS servers
    HELP
  else
    <<~HELP

      Commands:
        wifi proxy on/off/auto → set proxy mode (manual/none/auto)
        wifi proxy             → show proxy details
        wifi dns               → show DNS servers
        wifi dns set 8.8.8.8 8.8.4.4 → set DNS servers
    HELP
  end
end

run
